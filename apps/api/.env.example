# [必須] API 認証キー。強力なランダム値を設定すること。
# 例: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 未設定 / 既定値のままだと本番 (DEBUG=false) では起動を拒否する。
API_KEY=your-secret-key-here

# CORS 許可オリジン (カンマ区切り)。財務 API のためワイルドカード不可。
# 通常は Next.js サーバからの server-to-server 呼び出しのため空でよい。
# ブラウザから直接叩く場合のみ設定: CORS_ORIGINS=https://app.example.com
CORS_ORIGINS=

# アップロード PDF の最大バイト数 (DoS 対策, 既定 15MB)
MAX_UPLOAD_BYTES=15728640

# AI 再分類の有効化。既定 false = ルールベースのみ (AI 課金ゼロ)。
# コストを抑えたい場合は false のまま。有効化時のみ下のキーが必要。
# 有効時も「1 PDF = 1 バッチ呼び出し + 重複排除 + プロセスキャッシュ」で
# コストを最小化する。
AI_ENABLED=false

# AI 分類プロバイダ: openrouter (推奨) | anthropic
AI_PROVIDER=openrouter
# OpenRouter を使う場合 (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# Anthropic API を直接使う場合 (後方互換)。
# 未設定でも動作する (ルールベース分類のみで動く)。
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DEBUG=false
