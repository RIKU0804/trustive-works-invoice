NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
PYTHON_API_URL=https://your-api.railway.app
PYTHON_API_KEY=your-secret-key

# Google OAuth (used by supabase/config.toml via env() substitution)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=<google-oauth-client-id>
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=<google-oauth-client-secret>
