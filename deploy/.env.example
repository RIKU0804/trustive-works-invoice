###############################################################################
# Invoice SaaS — Self-hosted Supabase deployment
#
# Copy to .env, then either:
#   • Run ./init.sh                 (auto-generates secrets)
#   • Or fill all values manually   (use openssl/python — see deploy/README.md)
###############################################################################

# ─── Public URLs ─────────────────────────────────────────────────────────────
# Domain that serves the Next.js Web app:        https://invoice.example.com
DOMAIN=invoice.example.com
# Subdomain that serves the Supabase API gateway: https://api.invoice.example.com
API_DOMAIN=api.invoice.example.com
# Subdomain (optional) for Supabase Studio:       https://studio.invoice.example.com
STUDIO_DOMAIN=studio.invoice.example.com
# Email used by Caddy to register Let's Encrypt account
ACME_EMAIL=admin@example.com

# Public URLs derived from the domains above (must match what the browser uses).
SITE_URL=https://invoice.example.com
API_EXTERNAL_URL=https://api.invoice.example.com
ADDITIONAL_REDIRECT_URLS=https://invoice.example.com,https://invoice.example.com/**

# ─── Postgres ────────────────────────────────────────────────────────────────
# Strong random password (>= 32 chars). Used by every Supabase service.
POSTGRES_PASSWORD=please-change-me-32chars-minimum

# ─── JWT / API Keys (Supabase) ───────────────────────────────────────────────
# 32-byte secret used to sign JWTs. Must be the SAME for db / auth / rest / realtime / storage.
# Generate: openssl rand -base64 48 | tr -d '\n'
JWT_SECRET=please-change-me-32chars-minimum-jwt-secret

# 64-byte secret used by Realtime
# Generate: openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=please-change-me-64chars-minimum-realtime-secret-key-base-padding

# JWTs derived from JWT_SECRET. Generate via deploy/init.sh or any JWT signing
# tool (Node/Python/jwt.io). Payloads:
#   anon:          { "role": "anon",         "iss": "supabase", "iat": now, "exp": now + 5y }
#   service_role:  { "role": "service_role", "iss": "supabase", "iat": now, "exp": now + 5y }
ANON_KEY=
SERVICE_ROLE_KEY=

# ─── Supabase Studio (admin dashboard) ───────────────────────────────────────
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=please-change-me-strong-pass
STUDIO_DEFAULT_ORGANIZATION=Invoice SaaS
STUDIO_DEFAULT_PROJECT=Invoice SaaS

# Logflare (analytics) — leave empty unless you wire it up.
LOGFLARE_PUBLIC_ACCESS_TOKEN=
LOGFLARE_PRIVATE_ACCESS_TOKEN=

# ─── Auth / Signup behaviour ────────────────────────────────────────────────
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
# In production, prefer false (require email confirmation).
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_GOOGLE_OAUTH=true

# ─── SMTP (optional — enables email confirmation, magic links, recovery) ─────
SMTP_ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=

# ─── OAuth providers (optional) ──────────────────────────────────────────────
# Google Cloud Console -> OAuth 2.0 Client ID
# Authorized redirect URI must be: ${API_EXTERNAL_URL}/auth/v1/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# ─── Application: Python API ────────────────────────────────────────────────
# Shared secret between the Next.js server and the Python API.
PYTHON_API_KEY=please-change-me-shared-secret

# Anthropic Claude API key (optional — enables AI re-classification).
ANTHROPIC_API_KEY=

# OpenRouter API key (optional — fallback / cheaper model).
OPENROUTER_API_KEY=

# ─── Networking (only override if 8000/8443 conflict on the host) ───────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
